# Azure AD App Registration
TEAMS_MCP_TENANT_ID=your-tenant-id
TEAMS_MCP_CLIENT_ID=your-client-id

# Optional: override scopes (comma-separated).
# By default uses .default which auto-detects all permissions
# configured and consented on the app registration.
# Only set this if you need to restrict scopes further:
# TEAMS_MCP_SCOPES=User.Read,Chat.Read,Chat.ReadWrite,Team.ReadBasic.All

# Recommended delegated permissions to add in Azure Portal:
#
# No admin consent needed:
#   User.Read, User.ReadBasic.All, Team.ReadBasic.All, Channel.ReadBasic.All,
#   ChannelMessage.Send, Chat.Read, Chat.ReadWrite, Presence.Read.All
#
# Require admin consent:
#   TeamMember.Read.All      - list_team_members
#   ChannelMember.Read.All   - list_channel_members
#   ChannelMessage.Read.All  - list_channel_messages, list_thread_replies
#   ChannelMessage.ReadWrite - delete_message, update_message (in channels)
