# Azure AD App Registration
TEAMS_MCP_TENANT_ID=your-tenant-id
TEAMS_MCP_CLIENT_ID=your-client-id

# Required: comma-separated list of Microsoft Graph delegated scopes.
# Only request scopes your admin has granted consent for.
#
# All scopes (requires admin consent for marked ones):
TEAMS_MCP_SCOPES=User.Read,User.ReadBasic.All,Team.ReadBasic.All,TeamMember.Read.All,Channel.ReadBasic.All,ChannelMember.Read.All,ChannelMessage.Read.All,ChannelMessage.Send,ChannelMessage.ReadWrite,Chat.Read,Chat.ReadWrite,Presence.Read.All

# Minimal set (no admin consent needed):
# TEAMS_MCP_SCOPES=User.Read,User.ReadBasic.All,Team.ReadBasic.All,Channel.ReadBasic.All,ChannelMessage.Send,Chat.Read,Chat.ReadWrite,Presence.Read.All
#
# Scopes requiring admin consent:
#   TeamMember.Read.All      - list_team_members
#   ChannelMember.Read.All   - list_channel_members
#   ChannelMessage.Read.All  - list_channel_messages, list_thread_replies
#   ChannelMessage.ReadWrite - delete_message, update_message (in channels)
