# Azure AD App Registration
TEAMS_MCP_TENANT_ID=your-tenant-id
TEAMS_MCP_CLIENT_ID=your-client-id

# Optional: override requested scopes (comma-separated, no spaces).
# By default all 12 scopes are requested. If login fails with "Need admin approval",
# either ask your admin to grant consent, or use only user-consentable scopes:
# TEAMS_MCP_SCOPES=User.Read,User.ReadBasic.All,Team.ReadBasic.All,Channel.ReadBasic.All,ChannelMessage.Send,Chat.Read,Chat.ReadWrite,Presence.Read.All

# All delegated permissions (configure in Azure Portal):
#
# No admin consent needed:
#   User.Read, User.ReadBasic.All, Team.ReadBasic.All, Channel.ReadBasic.All,
#   ChannelMessage.Send, Chat.Read, Chat.ReadWrite, Presence.Read.All
#
# Require admin consent:
#   TeamMember.Read.All, ChannelMember.Read.All,
#   ChannelMessage.Read.All, ChannelMessage.ReadWrite
